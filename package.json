{
  "name": "astro-vue-cf-starter",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "description": "Content-managed static-site starter: Astro + Vue admin island + Cloudflare Pages.",
  "scripts": {
    "setup": "node cli/setup.mjs",
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "check": "astro check",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "stylelint": "stylelint \"src/**/*.css\"",
    "validate:html": "html-validate \"dist/**/*.html\"",
    "test": "vitest run",
    "verify": "npm run check && npm run lint && npm run stylelint && npm run format:check && npm run test",
    "prepare": "simple-git-hooks"
  },
  "simple-git-hooks": {
    "pre-commit": "npm run check && npm run lint && npm run test"
  },
  "license": "ISC",
  "dependencies": {
    "@astrojs/sitemap": "3.7.3",
    "@astrojs/vue": "6.0.1",
    "@playform/compress": "0.2.3",
    "@tailwindcss/vite": "4.3.0",
    "astro": "6.4.4",
    "astro-icon": "1.1.5",
    "js-yaml": "4.2.0",
    "tailwindcss": "4.3.0",
    "vue": "3.5.35"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.9",
    "@cloudflare/workers-types": "4.20260604.1",
    "@eslint/js": "10.0.1",
    "@types/js-yaml": "4.0.9",
    "astro-eslint-parser": "1.4.0",
    "eslint": "10.4.1",
    "eslint-plugin-astro": "1.7.0",
    "eslint-plugin-vue": "10.9.2",
    "html-validate": "11.4.0",
    "prettier": "3.8.3",
    "prettier-plugin-astro": "0.14.1",
    "simple-git-hooks": "2.13.1",
    "stylelint": "17.12.0",
    "stylelint-config-standard": "40.0.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.60.1",
    "vitest": "4.1.8",
    "vue-eslint-parser": "10.4.1",
    "wrangler": "4.98.0"
  }
}
