# Copy to .dev.vars for local `wrangler pages dev`. .dev.vars is gitignored.
# ENVIRONMENT=development makes /api middleware bypass Cloudflare Access auth.
ENVIRONMENT=development
GITHUB_TOKEN=ghp_your_fine_grained_pat
GITHUB_REPO=owner/repo
GITHUB_BRANCH=main
CF_ACCESS_TEAM_DOMAIN=yourteam.cloudflareaccess.com
CF_ACCESS_AUD=replace-with-access-application-aud
