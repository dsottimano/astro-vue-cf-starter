---
import { siteConfig, type Locale } from '../../../../config/site.config';
import { getPosts } from '../../../lib/posts';
import { useTranslations } from '../../../i18n';
import BaseLayout from '../../../layouts/BaseLayout.astro';

export function getStaticPaths() {
  return siteConfig.locales.map((locale) => ({ params: { locale } }));
}

const locale = Astro.params.locale as Locale;
const t = useTranslations(locale);
const posts = await getPosts(locale);
const fmt = new Intl.DateTimeFormat(locale, { dateStyle: 'medium' });
---

<BaseLayout title={`${t('blog.title')} — ${siteConfig.name}`} locale={locale}>
  <main class="wrap">
    <h1>{t('blog.title')}</h1>
    <ul class="posts">
      {
        posts.map((post) => (
          <li class="post">
            <p class="date">{fmt.format(post.data.publishDate)}</p>
            <h2>
              <a href={`/${locale}/blog/${post.data.slug}`}>{post.data.title}</a>
            </h2>
            {post.data.excerpt && <p class="excerpt">{post.data.excerpt}</p>}
            <a class="more" href={`/${locale}/blog/${post.data.slug}`}>
              {t('blog.readMore')} →
            </a>
          </li>
        ))
      }
    </ul>
  </main>
</BaseLayout>

<style>
  .wrap {
    max-width: 48rem;
    margin: 0 auto;
    padding: 2rem var(--space);
  }
  .posts {
    list-style: none;
    padding: 0;
    margin: 2rem 0 0;
    display: grid;
    gap: 2rem;
  }
  .post {
    border-bottom: 1px solid var(--color-border);
    padding-bottom: 2rem;
  }
  .date {
    color: var(--color-muted);
    font-size: 0.85rem;
    margin: 0 0 0.25rem;
  }
  .post h2 {
    margin: 0 0 0.5rem;
  }
  .post h2 a {
    color: var(--color-fg);
    text-decoration: none;
  }
  .excerpt {
    color: var(--color-muted);
    margin: 0 0 0.5rem;
  }
  .more {
    font-size: 0.9rem;
  }
</style>
